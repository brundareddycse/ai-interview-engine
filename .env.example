# Backend Configuration
PYTHON_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/interviewpro

# OpenAI / LLM
OPENAI_API_KEY=your_openai_key_here
